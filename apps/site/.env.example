VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_SUPABASE_KEEPALIVE_ENABLED=true
VITE_SUPABASE_KEEPALIVE_RPC=keepalive_ping

# Optional table mode. When this is set and VITE_SUPABASE_KEEPALIVE_RPC is empty,
# the site sends a HEAD select to this table instead of calling the RPC above.
# VITE_SUPABASE_KEEPALIVE_TABLE=profiles
