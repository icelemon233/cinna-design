{
  "name": "cinna-design-workspace",
  "private": true,
  "version": "0.2.0",
  "description": "Cinna Design monorepo: a cloud-soft dessert themed React component library.",
  "packageManager": "pnpm@11.5.2",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @cinna-design/site dev",
    "build": "pnpm -r build",
    "build:pages": "pnpm --filter @cinna-design/tokens build && pnpm --filter @cinna-design/icons build && pnpm --filter @cinna-design/react build && pnpm --filter @cinna-design/site build:pages",
    "deploy:pages": "bash scripts/deploy-github-pages.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @cinna-design/react test:run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.8"
  }
}
